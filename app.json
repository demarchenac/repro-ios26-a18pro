{
  "expo": {
    "name": "repro-ios26-a18pro",
    "slug": "repro-ios26-a18pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "16.4",
      "bundleIdentifier": "app.rondas.repro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Camera access for testing.",
        "NSPhotoLibraryUsageDescription": "Photo library access for testing.",
        "NSContactsUsageDescription": "Contacts access for testing.",
        "NSLocationWhenInUseUsageDescription": "Location access for testing."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rondas.repro"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-build-properties", { "ios": { "deploymentTarget": "16.4" } }],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "rondas",
          "organization": "demarchenac"
        }
      ],
      ["expo-contacts", { "contactsPermission": "Contacts access for testing." }],
      ["expo-location", { "locationWhenInUsePermission": "Location access for testing." }],
      ["expo-image-picker", { "photosPermission": "Photos access for testing.", "cameraPermission": "Camera access for testing." }],
      "expo-file-system",
      "expo-secure-store",
      "expo-image"
    ],
    "owner": "demarchenac",
    "extra": {
      "eas": {
        "projectId": "fec7618a-996f-41ab-8248-23fe5d2b2508"
      }
    }
  }
}
